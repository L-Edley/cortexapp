# ── AION Intelligence Core — Production Environment ─────────────────

# --- Provedores LLM (cadeia de fallback: GROQ → GEMINI → OPENAI → OLLAMA → MOCK) ---
# GROQ (recomendado): https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# GEMINI (fallback): https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# OPENAI (segundo fallback): https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# OLLAMA (local, sem API key)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# --- Busca Web ---
# Tavily API: https://app.tavily.com/home (grátis: 1000 consultas/mês)
# Sem esta chave, usa DuckDuckGo como fallback (gratuito, sem cadastro)
TAVILY_API_KEY=

# --- Autenticação ---
# JSON map de tenant_id → bearer_token
# Ex: {"cortex":"tok_abc123","tenant2":"tok_def456"}
AION_TENANT_TOKENS={}
AION_GLOBAL_TOKEN=

# --- Persistência ---
OBSIDIAN_VAULT_PATH=/obsidian
DATABASE_DIR=/data/tenants
VECTOR_STORE_PATH=/data/vectors

# --- Embeddings ---
SIMILARITY_THRESHOLD=0.65
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Pesquisa Noturna ---
NIGHT_RESEARCH_MAX_TOPICS=10
NIGHT_RESEARCH_TIME=03:00

# --- Servidor ---
HOST=0.0.0.0
PORT=8000
DEBUG=false
