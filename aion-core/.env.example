# ── AION Intelligence Core — Configuração ────────────────────────────
# Copie este arquivo para .env e preencha suas chaves.
# As chaves de API são lidas diretamente de os.environ pelos providers.

# --- Servidor ---
HOST=127.0.0.1
PORT=8000
DEBUG=true

# --- Provedores LLM (cadeia de fallback: GROQ → GEMINI → OPENAI → OLLAMA → MOCK) ---
# GROQ (recomendado, mais rápido)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# GEMINI (fallback)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OPENAI (segundo fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OLLAMA (local, sem API key)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# --- Busca Web ---
# Tavily API (para respostas atualizadas sobre eventos, notícias, etc.)
# Se não configurada, usa DuckDuckGo como fallback gratuito
TAVILY_API_KEY=

# --- Persistência ---
DATABASE_DIR=data/tenants
OBSIDIAN_VAULT_PATH=obsidian
VECTOR_STORE_PATH=data/vectors

# --- Embeddings ---
SIMILARITY_THRESHOLD=0.65
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Autenticação ---
# JSON: {"cortex":"tok_xxx","tenant2":"tok_yyy"}
AION_TENANT_TOKENS={}
AION_GLOBAL_TOKEN=

# --- Pesquisa Noturna ---
NIGHT_RESEARCH_MAX_TOPICS=10
NIGHT_RESEARCH_TIME=03:00
