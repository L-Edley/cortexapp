# Cortex - Configuração de IA
# Deixe vazio para usar o mock local (sem IA real)

AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# Exemplo com OpenAI:
# AI_PROVIDER=openai
# AI_API_KEY=sk-xxxx
# AI_BASE_URL=https://api.openai.com/v1
