# Cortex - Configuração de IA
# Deixe vazio para usar o mock local (sem IA real)

AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# Exemplo com OpenAI:
# AI_PROVIDER=openai
# AI_API_KEY=sk-xxxx
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# Exemplo com Gemini:
# AI_PROVIDER=gemini
# AI_API_KEY=xxxx
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# AI_MODEL=gemini-2.0-flash-lite

# Obsidian Local REST API (opcional)
# Desativado por padrão. Ative apenas para uso local.
# A chave pode ficar no client porque é para uso local/pessoal.
# Não use em ambiente público sem proteção adicional.
NEXT_PUBLIC_OBSIDIAN_REST_ENABLED=false
NEXT_PUBLIC_OBSIDIAN_REST_URL=http://127.0.0.1:27123
NEXT_PUBLIC_OBSIDIAN_API_KEY=

# Modo de armazenamento (opcional, padrão: local)
# local = apenas localStorage | firebase = Firebase + cache local | hybrid = Firebase + localStorage + Obsidian
NEXT_PUBLIC_STORAGE_MODE=local

# Firebase (opcional)
# Configure para habilitar sincronização Firestore + Auth
# Crie um projeto em https://console.firebase.google.com
# Ative Authentication (Google) e Firestore Database
# Copie as credenciais do Web SDK do projeto
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Emuladores Firebase (desenvolvimento local)
# NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST=127.0.0.1
# NEXT_PUBLIC_FIRESTORE_EMULATOR_PORT=8080
# NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1
# NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_PORT=9099

# ElevenLabs High-Quality TTS (opcional, fallback local do navegador)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
