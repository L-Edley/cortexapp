# Cortex - Configuração de IA
# Descomente o provider desejado e preencha a chave de API.

# Provider recomendado: OpenCode Zen
# Modelos: deepseek-v4-flash-free, minimax-m2.5-free, nemotron-3-super-free, big-pickle
# Endpoint: https://opencode.ai/zen/v1/chat/completions
# AI_PROVIDER=opencode
# OPENCODE_API_KEY=
# AI_MODEL=deepseek-v4-flash-free
# AION_PERSONALITY=secretary

# Alternativa: OpenRouter
# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-xxxx
# AI_MODEL=google/gemini-2.5-flash:free

# Alternativa: Google Gemini
# AI_PROVIDER=gemini
# AI_API_KEY=xxxx
# AI_MODEL=gemini-2.5-flash

# Groq (API compatível com OpenAI)
# Modelos: llama-3.1-8b-instant, llama-3.3-70b-versatile, mixtral-8x7b-32768
# Endpoint: https://api.groq.com/openai/v1
# AI_PROVIDER=groq
# GROQ_API_KEY=
# AI_MODEL=llama-3.1-8b-instant

# NVIDIA NIM (API compatível com OpenAI)
# Endpoint: https://integrate.api.nvidia.com/v1
# AI_PROVIDER=nvidia
# NVIDIA_API_KEY=
# AI_MODEL=meta/llama-3.1-8b-instruct

# Alternativa: mock (sem IA real)
# AI_PROVIDER=mock

# Ollama (opcional) — LLM local via ollama
# Necessário para LLM Router híbrido (nunca obrigatório)
# ENABLE_OLLAMA=false
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=mistral:7b-q4_k_m
# OLLAMA_PRIORITY=after-cloud

# Personalidade do Aion (opcional, padrão: secretary)
# secretary = secretária executiva | default = assistente padrão
# AION_PERSONALITY=secretary

# Obsidian Local REST API (opcional)
# Server-side (obrigatório para o proxy — use no .env.local, nunca NEXT_PUBLIC_):
# OBSIDIAN_REST_URL=http://127.0.0.1:27123
# OBSIDIAN_API_KEY=xxx

# Client-side (opcional, apenas para detectar se Obsidian está configurado):
NEXT_PUBLIC_OBSIDIAN_REST_URL=

# Modo de armazenamento (opcional, padrão: local)
NEXT_PUBLIC_STORAGE_MODE=local

# Firebase (opcional)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ElevenLabs High-Quality TTS (opcional, fallback local do navegador)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Web Search (opcional) — Google Programmable Search
# GOOGLE_SEARCH_API_KEY=chave_da_api
# GOOGLE_SEARCH_ENGINE_ID=id_do_mecanismo
