{
  "name": "cortex",
  "version": "1.0.0",
  "private": true,
  "description": "Cortex — Motor de organização pessoal, financeira e estratégica",
  "scripts": {
    "dev": "next dev",
    "dev:core": "cd aion-core && python run_core.py",
    "dev:full": "concurrently -n core,cortex -c cyan,magenta \"npm run dev:core\" \"npm run dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aion/sdk": "file:packages/aion-sdk",
    "@elevenlabs/client": "^1.7.0",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.1",
    "@huggingface/transformers": "^4.2.0",
    "@supabase/supabase-js": "^2.106.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.4.2",
    "firebase": "^12.13.0",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.4.9",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "tailwindcss": "4.1.11",
    "typescript": "5.9.3",
    "vitest": "^4.1.6"
  }
}
